{
  "manifest_version": 3,
  "name": "GridLeads — Review Scraper",
  "version": "0.1.0",
  "description": "Auto-scrape up to the 100 newest Google Maps reviews for each business in the GridLeads database, one at a time, skipping businesses already done.",
  "permissions": ["storage", "unlimitedStorage", "scripting", "tabs", "alarms", "activeTab", "declarativeNetRequest"],
  "host_permissions": [
    "https://www.google.com/*",
    "https://consent.google.com/*",
    "https://gridleads-wheat.vercel.app/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "action": {
    "default_title": "GridLeads Reviews",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps*", "https://www.google.com/maps/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://consent.google.com/*"],
      "js": ["content/consent.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
