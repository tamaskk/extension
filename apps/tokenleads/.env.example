# ── Required ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/leadtokens?appName=Cluster0
AUTH_SECRET=<openssl rand -hex 32>
APP_URL=http://localhost:3010
ADMIN_EMAIL=admin@example.com
CRON_SECRET=<openssl rand -hex 24>

# ── Optional — without these the app runs with dev-mode fallbacks ────────
# Email (Resend). Missing → emails land in the admin Outbox instead.
RESEND_API_KEY=
EMAIL_FROM=TokenLeads <no-reply@yourdomain.com>

# Payments (Stripe). Missing → purchases/subscriptions complete instantly in mock mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Error shipping (Sentry DSN). Missing → structured JSON logs on stdout only.
SENTRY_DSN=

# AI outreach (Anthropic). Missing → deterministic template fallback, labelled.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
