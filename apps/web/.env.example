# Copy to .env (local) or set in Vercel project settings.
# MongoDB connection string for the GridLeads dashboard.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/gridleads?retryWrites=true&w=majority

# Vapi (vapi.ai) outbound calling — Groups tab 📞 Call
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
