{
  "manifest_version": 3,
  "name": "GridLeads — Maps Lead Scraper",
  "version": "0.2.0",
  "description": "Scrape Google Maps businesses, detect who has no website, score the sales opportunity, organize by project, and export CSV.",
  "permissions": ["storage", "unlimitedStorage", "activeTab", "downloads", "scripting", "webRequest", "tabs", "alarms"],
  "host_permissions": ["https://www.google.com/*", "http://localhost:3000/*", "http://127.0.0.1:3000/*"],
  "action": {
    "default_title": "GridLeads",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
